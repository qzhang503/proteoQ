p
# Complementary columns
oths  <- !grps %in% g
dfRc <- dfsR[oths]
dfIc <- dfsI[oths]
# At least one group with >= 3 values from the complementary
okc <- lapply(dfIc, function (x) {
rowSums(!is.na(x), na.rm = TRUE) >= 3L
}) |>
purrr::reduce(`|`)
